# AI Job Hunter — Environment Configuration
#
# Copy this file to `.env` and fill in your values.
# `.env` is listed in .gitignore and must never be committed.
#
# All fields with defaults below are optional.
# Fields marked REQUIRED must be set before the application will start.

# =============================================================================
# AI Provider  (REQUIRED)
# =============================================================================

# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model to use for all AI tasks.
# Default: gemini-2.0-flash
AI_MODEL=gemini-2.0-flash

# Maximum tokens per AI response. Increase for longer resumes/cover letters.
# Default: 4096
AI_MAX_TOKENS=4096

# =============================================================================
# User Profile  (REQUIRED for personalised AI output)
# =============================================================================

USER_NAME=Your Full Name
USER_EMAIL=your@email.com

# Years of total engineering experience.
# Default: 3
USER_YEARS_EXPERIENCE=3

# Target seniority level (used in prompts and matching).
# Default: SDE2
USER_TARGET_LEVEL=SDE2

# =============================================================================
# Database
# =============================================================================

# SQLite path (default) or any SQLAlchemy-compatible URL.
# Default: sqlite:///./data/jobs.db
DATABASE_URL=sqlite:///./data/jobs.db

# =============================================================================
# Scraping / Browser
# =============================================================================

# Seconds to pause between requests to the same domain (be polite).
# Default: 2.0
SCRAPE_DELAY_SECONDS=2.0

# Page load and HTTP request timeout in seconds.
# Default: 30
REQUEST_TIMEOUT_SECONDS=30

# Number of retry attempts before marking a scrape as failed.
# Default: 3
MAX_RETRIES=3

# Set to true to hide the browser window (recommended for production/CI).
# Default: false (browser window is visible during development)
HEADLESS_BROWSER=false

# =============================================================================
# Notifications
# =============================================================================

# Master on/off switch for all notifications.
# Default: true
NOTIFICATIONS_ENABLED=true

# Hour of day (24h, local time) to deliver the daily job digest.
# Default: 8  (8:00 AM)
DAILY_DIGEST_HOUR=8

# =============================================================================
# Feature Flags
# =============================================================================

AI_RANKING_ENABLED=true
RESUME_TAILORING_ENABLED=true
COVER_LETTER_ENABLED=true
REFERRAL_ASSISTANT_ENABLED=true
INTERVIEW_PREP_ENABLED=true
